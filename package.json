{
  "name": "epson2paperless",
  "version": "0.1.0",
  "description": "Epson Scan to Computer protocol emulator — delivers scans to Paperless-ngx",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "scan": "tsx src/one-shot.ts",
    "printer-fingerprint": "tsx tools/printer-fingerprint.ts",
    "kill-dev": "node scripts/kill-dev.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "license": "MIT",
  "engines": {
    "node": ">=24.15.0"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.15.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  }
}
